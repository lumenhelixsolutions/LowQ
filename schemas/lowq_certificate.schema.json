    "version",
    "created_at",
    "confidence_level",
    "project",
    "baseline_run",
    "optimized_run",
    "delta",
    "proof_discipline",
    "rubic_audit",
    "caveat"
  ],
  "properties": {
    "proof_type": {
      "const": "LOWQ_THERMAL_DELTA_CERTIFICATE"
    },
    "version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "confidence_level": {
