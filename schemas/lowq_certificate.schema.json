      "type": [
        "object",
        "null"
      ]
    },
    "simulator_evidence": {
      "type": [
        "object",
        "null"
      ]
    },
    "proof_discipline": {
      "type": "object"
    },
    "rubic_audit": {
      "type": "object"
    },
    "caveat": {
      "type": "string"
    }
